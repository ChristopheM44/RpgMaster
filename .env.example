# === Ollama (Text LLM) ===
OLLAMA_BASE_URL=http://localhost:11434
GM_MODEL=mistral:7b
PLAYER_MODEL=mistral:7b

# === Voxtral TTS (vLLM-Omni) ===
VOXTRAL_BASE_URL=http://localhost:8091
VOXTRAL_MODEL=mistralai/Voxtral-4B-TTS-2603
VOXTRAL_ENABLED=false

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./rpgmaster.db

# === Application ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=info
APP_ACCESS_TOKEN=
RUNTIME_DIR=.runtime
CORS_ORIGINS=http://localhost:5173

# === Game Settings ===
DEFAULT_LANGUAGE=fr
MAX_CONTEXT_MESSAGES=20
MAX_PLAYER_ACTION_CHARS=4000
WS_EVENT_QUEUE_SIZE=256
TTS_ASYNC=true
LLM_BUDGET_MODE=sober
OLLAMA_MAX_CONCURRENT_REQUESTS=1

# === Frontend ===
VITE_RPGMASTER_ACCESS_TOKEN=
